# Create a bot via @BotFather and paste the token here
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Comma-separated admin chat IDs (can add/remove users from the bot).
# Send /id to the bot to get your chat ID.
ADMIN_CHAT_IDS=123456789

# Optional legacy name — used as admins if ADMIN_CHAT_IDS is empty.
# ALLOWED_CHAT_IDS=123456789

# Optional: root filesystem path to monitor (default: /)
# DISK_PATH=/

# Optional: custom mount to monitor instead of /
# DISK_PATH=/home

# --- Multi-server setup ---
# Run the Telegram bot on ONE host. On every other host, run agent.py instead.

# Friendly name for this host when the bot monitors it locally (optional)
# SERVER_NAME=Production

# Monitor the host running the bot (default: true). Set false if this machine is bot-only.
# MONITOR_LOCAL=true

# --- Agent (remote servers only) ---
# Generate a random string and use the same value when registering with /addserver
# AGENT_TOKEN=change-me-to-a-long-random-string
# AGENT_HOST=0.0.0.0
# AGENT_PORT=8765
