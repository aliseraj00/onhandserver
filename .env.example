# Create a bot via @BotFather and paste the token here
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Comma-separated Telegram user/chat IDs allowed to use this bot.
# Message @userinfobot to get your ID.
ALLOWED_CHAT_IDS=123456789

# Optional: root filesystem path to monitor (default: /)
# DISK_PATH=/

# Optional: custom mount to monitor instead of /
# DISK_PATH=/home
