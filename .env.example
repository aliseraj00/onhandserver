# Create a bot via @BotFather and paste the token here
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Comma-separated admin chat IDs (can add/remove users from the bot).
ADMIN_CHAT_IDS=123456789

# Optional: root filesystem path to monitor (default: /)
# DISK_PATH=/

# Friendly name for this host when the bot monitors it locally (optional)
# SERVER_NAME=Production

# Monitor the host running the bot (default: true)
# MONITOR_LOCAL=true

# --- Bot: agent hub (remote agents connect HERE) ---
# AGENT_HUB_HOST=0.0.0.0
# AGENT_HUB_PORT=8766
# Public IP/hostname remote agents use (your bot server's address)
# AGENT_HUB_PUBLIC_HOST=203.0.113.10

# --- Agent (remote servers) — connects OUT to the bot ---
# AGENT_NAME=Production
# AGENT_TOKEN=change-me-to-a-long-random-string
# BOT_SERVER_HOST=203.0.113.10
# BOT_SERVER_PORT=8766
# PUSH_INTERVAL=30
